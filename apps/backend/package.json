{
  "name": "@closed-ai/backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm run dev:api & pnpm run agent:dev",
    "dev:api": "tsx watch src/index.ts",
    "agent:dev": "tsx src/agents/closedai-agent.ts dev",
    "agent:start": "tsx src/agents/closedai-agent.ts start",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@closed-ai/types": "workspace:*",
    "@livekit/agents": "^1.3.0",
    "@livekit/agents-plugin-deepgram": "^1.3.0",
    "@livekit/agents-plugin-elevenlabs": "^1.3.0",
    "@livekit/agents-plugin-openai": "^1.3.0",
    "@livekit/agents-plugin-silero": "^1.3.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "livekit-server-sdk": "^2.15.1",
    "mongoose": "^8.19.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.6",
    "@types/pdf-parse": "^1.1.5",
    "eslint": "^9.39.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
